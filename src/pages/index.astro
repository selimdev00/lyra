---
import { getEntry } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SectionHero from "../components/SectionHero.astro";
import SectionIntro from "../components/SectionIntro.astro";
import SectionComposition from "../components/SectionComposition.astro";
import SectionAudience from "../components/SectionAudience.astro";
import SectionComparison from "../components/SectionComparison.astro";
import SectionPurchase from "../components/SectionPurchase.astro";
import SectionFaq from "../components/SectionFaq.astro";
import SectionContact from "../components/SectionContact.astro";
import SiteFooter from "../components/SiteFooter.astro";

const page = await getEntry("landing", "page");
if (!page) {
  throw new Error("Landing content missing: src/content/landing/page.yml");
}
const data = page.data;

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: "Complex SW Суставы",
  description: `${data.composition.titleLead} ${data.composition.titleAccent}`.trim(),
  brand: { "@type": "Brand", name: "Оптисалт" },
  category: "Dietary supplement",
  offers: {
    "@type": "Offer",
    priceCurrency: "RUB",
    price: data.purchase.price.replace(/[^\d]/g, ""),
    availability: "https://schema.org/InStock",
  },
};

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "FMF",
  url: Astro.site?.toString(),
  email: data.contacts.email,
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: data.faq.items
    .filter((i) => !!i.a)
    .map((i) => ({
      "@type": "Question",
      name: i.q,
      acceptedAnswer: { "@type": "Answer", text: i.a },
    })),
};
---

<BaseLayout title={data.seo.title} description={data.seo.description} ogImage={data.seo.ogImage}>
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify({ "@context": "https://schema.org", "@graph": [productSchema, orgSchema, faqSchema] })}
  />

  <SiteHeader {...data.header} />

  <main>
    <SectionHero {...data.hero} />
    <SectionIntro {...data.intro} benefits={data.benefits.items} />
    <SectionComposition {...data.composition} />
    <SectionAudience {...data.audience} />
    <SectionComparison {...data.comparison} />
    <SectionPurchase {...data.purchase} />
    <SectionFaq {...data.faq} />
    <SectionContact {...data.contacts} />
  </main>

  <SiteFooter {...data.footer} />
</BaseLayout>
