---
import CtaButton from "./CtaButton.astro";

interface NavItem { label: string; href: string }
interface Props {
  logo: string;
  brandLabel: string;
  nav: NavItem[];
  cta: { label: string; href: string };
}
const { logo, brandLabel, nav, cta } = Astro.props;
---

<header data-site-header class="site-header">
  <div class="site-header__inner container-page">
    <button class="site-header__burger" type="button" data-menu-toggle aria-label="Открыть меню" aria-expanded="false" aria-controls="mobile-nav">
      <svg class="site-header__icon site-header__icon--burger" width="20" height="14" viewBox="0 0 20 14" fill="none" aria-hidden="true">
        <path d="M1 1h18M1 7h18M1 13h18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
      </svg>
      <svg class="site-header__icon site-header__icon--close" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
        <path d="M1 1l16 16M17 1L1 17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
      </svg>
    </button>

    <a href="/" class="site-header__brand" aria-label={`${brandLabel} - на главную`}>
      <img src={logo} alt={brandLabel} width="157" height="60" class="site-header__logo" />
    </a>

    <nav aria-label="Меню" class="site-header__nav">
      {nav.map((item) => (
        <a href={item.href} class="site-header__nav-link">{item.label}</a>
      ))}
    </nav>

    <CtaButton label={cta.label} href={cta.href} variant="white" class="site-header__cta" />

    <a href={cta.href} class="site-header__cart" aria-label={cta.label}>
      <img src="/img/icon-cart.svg" alt="" width="22" height="22" />
    </a>
  </div>

  <div class="site-header__drawer" id="mobile-nav" data-menu-drawer aria-hidden="true" inert>
    <nav aria-label="Мобильное меню" class="site-header__drawer-nav">
      {nav.map((item) => (
        <a href={item.href} data-menu-link>{item.label}</a>
      ))}
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: fixed;
    inset-inline: 0;
    top: 0;
    z-index: 40;
    background: transparent;
    border-bottom: 1px solid transparent;
    transition: background 0.3s, border-color 0.3s, backdrop-filter 0.3s;
  }
  .site-header__nav-link {
    padding: 8px 4px;
    transition: color 0.2s;
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding-block: 20px;
  }
  .site-header__brand { display: flex; align-items: center; }
  .site-header__logo { height: 60px; width: auto; display: block; }
  .site-header__nav {
    display: flex;
    align-items: center;
    gap: 32px;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 20px;
    line-height: 1.2;
  }
  .site-header__nav a { color: rgba(255, 255, 255, 0.9); }
  .site-header__nav a:hover { color: #fff; }

  .site-header__burger,
  .site-header__cart {
    display: none;
    width: 40px;
    height: 40px;
    background: transparent;
    border: 0;
    padding: 0;
    color: #fff;
    cursor: pointer;
    position: relative;
  }
  .site-header__burger[aria-expanded="true"],
  .site-header.is-scrolled .site-header__burger[aria-expanded="true"] {
    color: #fff !important;
    position: relative;
    z-index: 10;
  }

  .site-header.is-scrolled {
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: saturate(140%) blur(10px);
    border-bottom-color: var(--color-line);
  }
  .site-header.is-menu-open {
    backdrop-filter: none !important;
    -webkit-backdrop-filter: none !important;
    background: transparent !important;
    border-bottom-color: transparent !important;
  }
  .site-header.is-scrolled .site-header__logo {
    filter: brightness(0) saturate(100%) invert(40%) sepia(74%) saturate(489%) hue-rotate(160deg) brightness(95%) contrast(91%);
  }
  .site-header.is-scrolled .site-header__nav a { color: var(--color-ink-soft); }
  .site-header.is-scrolled .site-header__nav a:hover { color: var(--color-brand); }
  .site-header.is-scrolled :global(.site-header__cta .cta-btn__label),
  .site-header.is-scrolled :global(.site-header__cta .cta-btn__icon) {
    background: var(--color-brand) !important;
    color: #fff !important;
  }
  .site-header.is-scrolled :global(.site-header__cta:hover .cta-btn__label),
  .site-header.is-scrolled :global(.site-header__cta:hover .cta-btn__icon) {
    background: var(--color-brand-hover) !important;
  }
  .site-header.is-scrolled .site-header__burger,
  .site-header.is-scrolled .site-header__cart { color: var(--color-brand-deep); }
  .site-header.is-scrolled .site-header__cart img {
    filter: brightness(0) saturate(100%);
  }

  .site-header__drawer {
    position: fixed;
    inset: 0;
    background: rgba(16, 42, 68, 0.96);
    backdrop-filter: blur(8px);
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 96px 24px 48px;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-8px);
    transition: opacity 0.3s var(--ease-out-soft),
                transform 0.3s var(--ease-out-soft),
                visibility 0s linear 0.3s;
  }
  .site-header__drawer.is-open {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    transition: opacity 0.3s var(--ease-out-soft),
                transform 0.3s var(--ease-out-soft),
                visibility 0s linear 0s;
  }
  .site-header__drawer-nav {
    display: flex;
    flex-direction: column;
    gap: 24px;
    width: 100%;
    max-width: 320px;
    text-align: left;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 22px;
  }
  .site-header__drawer-nav a {
    color: #fff;
    padding: 12px 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.35s var(--ease-out-soft),
                transform 0.35s var(--ease-out-soft);
  }
  .site-header__drawer.is-open .site-header__drawer-nav a {
    opacity: 1;
    transform: translateY(0);
  }
  .site-header__drawer.is-open .site-header__drawer-nav a:nth-child(1) { transition-delay: 0.12s; }
  .site-header__drawer.is-open .site-header__drawer-nav a:nth-child(2) { transition-delay: 0.18s; }
  .site-header__drawer.is-open .site-header__drawer-nav a:nth-child(3) { transition-delay: 0.24s; }
  .site-header__drawer.is-open .site-header__drawer-nav a:nth-child(4) { transition-delay: 0.30s; }
  .site-header__drawer.is-open .site-header__drawer-nav a:nth-child(5) { transition-delay: 0.36s; }
  .site-header__drawer.is-open .site-header__drawer-nav a:nth-child(6) { transition-delay: 0.42s; }

  .site-header__icon--burger,
  .site-header__icon--close {
    transition: opacity 0.25s var(--ease-out-soft),
                transform 0.3s var(--ease-out-soft);
  }
  .site-header__burger[aria-expanded="true"] .site-header__icon--burger {
    opacity: 0;
    transform: rotate(-90deg);
  }
  .site-header__burger[aria-expanded="false"] .site-header__icon--close {
    opacity: 0;
    transform: rotate(90deg);
  }
  .site-header__burger .site-header__icon--burger,
  .site-header__burger .site-header__icon--close {
    grid-area: 1 / 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .site-header__drawer,
    .site-header__drawer.is-open,
    .site-header__drawer-nav a,
    .site-header__icon--burger,
    .site-header__icon--close {
      transition: none !important;
    }
  }

  @media (max-width: 1023px) {
    .site-header__inner { padding-block: 8px; padding-inline: 16px; }
    .site-header__nav { display: none !important; }
    .site-header__burger { display: grid; place-items: center; }
    .site-header__cart { display: inline-flex; align-items: center; justify-content: center; }
    .site-header__logo { height: 28px; }
    .site-header__brand { flex: 1; justify-content: center; }
  }
</style>

<script>
  const header = document.querySelector<HTMLElement>("[data-site-header]");
  if (header) {
    const onScroll = () => header.classList.toggle("is-scrolled", window.scrollY > 24);
    onScroll();
    window.addEventListener("scroll", onScroll, { passive: true });
  }

  const toggle = document.querySelector<HTMLButtonElement>("[data-menu-toggle]");
  const drawer = document.querySelector<HTMLElement>("[data-menu-drawer]");
  if (toggle && drawer) {
    const setOpen = (open: boolean) => {
      toggle.setAttribute("aria-expanded", open ? "true" : "false");
      drawer.classList.toggle("is-open", open);
      drawer.setAttribute("aria-hidden", open ? "false" : "true");
      if (open) drawer.removeAttribute("inert");
      else drawer.setAttribute("inert", "");
      document.body.style.overflow = open ? "hidden" : "";
      header?.classList.toggle("is-menu-open", open);
    };
    toggle.addEventListener("click", () => {
      setOpen(toggle.getAttribute("aria-expanded") !== "true");
    });
    drawer.querySelectorAll("[data-menu-link]").forEach((a) =>
      a.addEventListener("click", () => setOpen(false))
    );
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && toggle.getAttribute("aria-expanded") === "true") setOpen(false);
    });
  }
</script>
