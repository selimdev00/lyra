---
import CtaButton from "./CtaButton.astro";

interface Props {
  title: string;
  subtitle: string;
  cta: { label: string; href: string };
  product: { image: string; alt: string };
  meta: { weight: string; course: string };
  kicker: { title: string; body: string };
}
const { title, subtitle, cta, product, meta, kicker } = Astro.props;
const titleLines = title.split(" ");
---

<section class="hero">
  <picture class="absolute inset-0 -z-20">
    <source srcset="/img/hero-bg.webp" type="image/webp" />
    <img
      src="/img/hero-bg.jpg"
      alt=""
      width="1920"
      height="1080"
      loading="eager"
      decoding="async"
      fetchpriority="high"
      class="w-full h-full object-cover object-right"
    />
  </picture>

  <div
    aria-hidden="true"
    class="absolute inset-0 -z-10 bg-gradient-to-r from-brand-deep/55 via-brand-dark/25 to-transparent"
  ></div>

  <div class="hero-grid container-page relative h-full">
    <div class="hero-left">
      <h1 class="hero-title">
        <span>{titleLines[0]}</span>
        <span>{titleLines.slice(1).join(" ")}</span>
      </h1>

      <div class="hero-above-line">
        <p class="hero-subtitle mt-3">{subtitle}</p>
        <CtaButton label={cta.label} href={cta.href} variant="white" size="lg" class="hero-cta" />
      </div>
    </div>

    <div class="hero-meta">
      <p class="hero-meta__weight">{meta.weight}</p>
      <p class="hero-meta__course">{meta.course}</p>
    </div>

    <hr class="hero-divider" aria-hidden="true" />

    <img
      src={product.image}
      alt={product.alt}
      width="900"
      height="900"
      loading="eager"
      decoding="async"
      fetchpriority="high"
      class="hero-banka select-none"
    />

    <div class="hero-kicker">
      <p class="hero-kicker__title">{kicker.title}</p>
      <p class="hero-kicker__body">{kicker.body}</p>
    </div>
  </div>
</section>

