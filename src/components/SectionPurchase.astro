---
interface Props {
  title: string;
  price: string;
  oldPrice?: string;
  note: string;
  image: string;
  ctaLabel: string;
  ctaHref: string;
}
const { title, price, oldPrice, note, image, ctaLabel, ctaHref } = Astro.props;
---

<section id="order" class="bg-surface py-16 lg:py-24">
  <div class="container-page">
    <div class="bg-white rounded-card shadow-card ring-1 ring-line/60 overflow-hidden grid lg:grid-cols-[1fr_1.2fr] gap-0">
      <div class="bg-gradient-to-br from-surface-2 to-surface flex items-center justify-center p-8 lg:p-12">
        <img
          src={image}
          alt="Сустави 365 — упаковка"
          width="480"
          height="480"
          loading="lazy"
          decoding="async"
          class="max-w-sm w-full"
        />
      </div>

      <div class="p-8 lg:p-12 flex flex-col justify-center gap-6">
        <h2 class="text-3xl lg:text-4xl font-semibold text-brand-deep">{title}</h2>

        <div class="flex items-baseline gap-4 flex-wrap">
          <span class="text-4xl lg:text-5xl font-bold text-brand">{price}</span>
          {oldPrice && (
            <span class="text-xl text-muted line-through">{oldPrice}</span>
          )}
        </div>

        <p class="text-ink-soft">{note}</p>

        <a href={ctaHref} class="btn-primary self-start">
          {ctaLabel}
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M5 12h14m-6-6 6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
