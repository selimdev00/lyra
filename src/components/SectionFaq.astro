---
interface FaqItem {
  q: string;
  a?: string;
}
interface Props {
  title: string;
  items: FaqItem[];
}
const { title, items } = Astro.props;
---

<section id="faq" class="faq-section">
  <div class="container-page">
    <ul class="faq-list" data-reveal-stagger>
      {items.map((it, i) => (
        <li class={`faq-item ${i === 1 && it.a ? "is-open" : ""}`} data-faq-item>
          <button type="button" class="faq-summary" data-faq-toggle aria-expanded={i === 1 && !!it.a ? "true" : "false"}>
            <span class="faq-q">{it.q}</span>
            <span class="faq-toggle" aria-hidden="true">
              <img class="faq-toggle__plus" src="/img/icon-faq-plus.svg" alt="" width="24" height="24" />
              <img class="faq-toggle__minus" src="/img/icon-faq-minus.svg" alt="" width="24" height="24" />
            </span>
          </button>
          {it.a && (
            <div class="faq-body">
              <div class="faq-body-inner">
                <p class="faq-a">{it.a}</p>
              </div>
            </div>
          )}
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .faq-section {
    background: var(--color-surface);
    padding-block: var(--space-section);
  }
  .faq-list {
    list-style: none;
    margin: 0 auto;
    padding: 0;
    max-width: 1530px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .faq-item {
    background: #fff;
    border-radius: var(--radius-card);
    overflow: hidden;
  }
  .faq-summary {
    width: 100%;
    background: transparent;
    border: 0;
    padding: 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    cursor: pointer;
    text-align: left;
    font: inherit;
    color: inherit;
  }
  .faq-q {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 24px;
    line-height: 1;
    color: var(--color-ink);
  }
  .faq-toggle {
    flex-shrink: 0;
    color: var(--color-brand);
    width: 24px;
    height: 24px;
    display: grid;
    place-items: center;
  }
  .faq-toggle img {
    width: 24px;
    height: 24px;
  }
  .faq-toggle .faq-toggle__plus { display: block; }
  .faq-toggle .faq-toggle__minus { display: none; }
  .faq-item.is-open .faq-toggle .faq-toggle__plus { display: none; }
  .faq-item.is-open .faq-toggle .faq-toggle__minus { display: block; }
  .faq-body {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.35s var(--ease-out-soft);
  }
  .faq-item.is-open .faq-body {
    grid-template-rows: 1fr;
  }
  .faq-body-inner {
    min-height: 0;
    overflow: hidden;
  }
  .faq-a {
    margin: 0;
    padding: 0 24px 24px;
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 18px;
    line-height: 1.2;
    color: var(--color-muted);
  }

  @media (max-width: 1023px) {
    .faq-section {
      padding-block: var(--space-section-mobile);
      padding-inline: 16px;
    }
    .faq-section .container-page { padding-inline: 0; }
    .faq-list { max-width: 100%; }
    .faq-item { border-radius: var(--radius-mobile); }
    .faq-summary { padding: 16px; gap: 16px; }
    .faq-q { font-size: 18px; line-height: 1; }
    .faq-a {
      padding: 0 16px 16px;
      font-size: 14px;
      line-height: 1.2;
    }
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>("[data-faq-toggle]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const item = btn.closest("[data-faq-item]");
      if (!item) return;
      const open = item.classList.toggle("is-open");
      btn.setAttribute("aria-expanded", open ? "true" : "false");
    });
  });
</script>
