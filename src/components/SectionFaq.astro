---
interface Props {
  title: string;
  formNoteLabel: string;
  submitLabel: string;
  consentText: string;
}
const { title, formNoteLabel, submitLabel, consentText } = Astro.props;
---

<section id="faq" class="container-page py-16 lg:py-24">
  <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-start">
    <div class="space-y-4">
      <h2 class="text-3xl lg:text-5xl font-semibold text-brand-deep leading-tight">
        {title}
      </h2>
      <p class="text-lg text-ink-soft">{formNoteLabel}</p>
    </div>

    <form
      class="bg-white rounded-card shadow-card ring-1 ring-line/60 p-6 lg:p-8 space-y-4"
      action="/api/lead"
      method="post"
      novalidate
      data-form="lead"
    >
      <div class="space-y-1.5">
        <label for="lead-name" class="text-sm font-medium text-brand-deep">Как к вам обращаться</label>
        <input
          id="lead-name"
          name="name"
          type="text"
          required
          autocomplete="name"
          class="w-full px-4 py-3 rounded-tile bg-surface ring-1 ring-line focus:ring-brand focus:bg-white outline-none transition"
          placeholder="Имя"
        />
      </div>

      <div class="space-y-1.5">
        <label for="lead-phone" class="text-sm font-medium text-brand-deep">Телефон</label>
        <input
          id="lead-phone"
          name="phone"
          type="tel"
          inputmode="tel"
          required
          autocomplete="tel"
          pattern="^[\d\s\+\-\(\)]+$"
          class="w-full px-4 py-3 rounded-tile bg-surface ring-1 ring-line focus:ring-brand focus:bg-white outline-none transition"
          placeholder="+7 (___) ___-__-__"
        />
      </div>

      <div class="space-y-1.5">
        <label for="lead-message" class="text-sm font-medium text-brand-deep">Сообщение</label>
        <textarea
          id="lead-message"
          name="message"
          rows="3"
          class="w-full px-4 py-3 rounded-tile bg-surface ring-1 ring-line focus:ring-brand focus:bg-white outline-none transition resize-none"
          placeholder="Опишите вопрос — мы перезвоним"
        ></textarea>
      </div>

      <button type="submit" class="btn-primary w-full justify-center">{submitLabel}</button>

      <p class="text-xs text-muted leading-relaxed">{consentText}</p>

      <p data-form-status="" class="hidden text-sm text-brand-dark" role="status"></p>
    </form>
  </div>
</section>

<script>
  const form = document.querySelector<HTMLFormElement>('form[data-form="lead"]');
  const status = form?.querySelector<HTMLElement>("[data-form-status]");
  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }
    const fd = new FormData(form);
    const payload = Object.fromEntries(fd.entries());
    if (status) {
      status.classList.remove("hidden");
      status.textContent = "Спасибо! Мы свяжемся в течение 15 минут.";
    }
    form.reset();
    if (typeof window !== "undefined") {
      window.dispatchEvent(new CustomEvent("lead:submitted", { detail: payload }));
    }
  });
</script>
