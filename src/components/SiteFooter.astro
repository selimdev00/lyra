---
interface Props {
  logo: string;
  copyright: string;
  rights: string;
  disclaimer: string;
  links: { label: string; href: string }[];
}
const { logo, copyright, rights, disclaimer, links } = Astro.props;
---

<footer class="ft">
  <div class="container-page ft-grid">
    <div class="ft-left">
      <p>{copyright}</p>
      <p>{rights}</p>
    </div>

    <div class="ft-center">
      <img src={logo} alt="FMF" width="162" height="62" loading="lazy" decoding="async" />
      <p class="ft-disclaimer">{disclaimer}</p>
    </div>

    <div class="ft-right">
      {links.map((l) => (
        <a href={l.href}>{l.label}</a>
      ))}
    </div>
  </div>
</footer>

<style>
  .ft {
    background: #fff;
    border-top: 1px solid #ebebeb;
  }
  .ft-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
    gap: 32px;
    padding-block: 40px;
    align-items: end;
  }
  .ft-left p, .ft-right a {
    font-family: "Onest", sans-serif;
    font-weight: 400;
    font-size: 18px;
    line-height: 1.2;
    color: #1c1c1c;
    margin: 0;
  }
  .ft-left p + p, .ft-right a + a { margin-top: 12px; }
  .ft-center {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    max-width: 596px;
  }
  .ft-center img {
    height: 62px;
    width: auto;
  }
  .ft-disclaimer {
    font-family: "Onest", sans-serif;
    font-weight: 400;
    font-size: 14px;
    line-height: 1.2;
    color: #6b6b6b;
    text-align: center;
  }
  .ft-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    text-align: right;
  }
  .ft-right a {
    text-decoration: underline;
  }

  @media (max-width: 1023px) {
    .ft-grid {
      grid-template-columns: 1fr;
      gap: 32px;
      padding: 16px 16px 16px;
      align-items: stretch;
      text-align: left;
    }
    .ft-center {
      order: 1;
      align-items: flex-start;
      gap: 12px;
      max-width: 100%;
    }
    .ft-center img {
      height: 55px;
    }
    .ft-disclaimer {
      text-align: left;
      max-width: 343px;
    }
    .ft-right {
      order: 2;
      align-items: flex-start;
      text-align: left;
      gap: 8px;
    }
    .ft-right a {
      font-size: 16px;
      text-decoration: none;
      margin-top: 0 !important;
    }
    .ft-left {
      order: 3;
      align-items: flex-start;
      text-align: left;
    }
    .ft-left p {
      font-size: 16px;
      margin-top: 0 !important;
    }
    .ft-left p + p { margin-top: 8px !important; }
  }
</style>
