---
import CtaButton from "./CtaButton.astro";

interface Props {
  title: string;
  description: string[];
  banka: string;
  course: { title: string; body: string; cta: { label: string; href: string } };
  portion: { title: string; body: string };
}
const { title, description, banka, course, portion } = Astro.props;
---

<section id="comparison" class="cmp-section">
  <div class="container-page cmp-grid">
    <header class="cmp-head" data-reveal>
      <h2 class="cmp-title">{title}</h2>
      <div class="cmp-desc">
        {description.map((p) => <p>{p}</p>)}
      </div>
    </header>

    <picture class="cmp-banka" aria-hidden="true">
      <source media="(max-width: 1023px)" srcset="/img/banka-straight.webp" type="image/webp" />
      <source srcset={banka} type="image/webp" />
      <img src="/img/banka.png" alt="" width="600" height="600" loading="lazy" decoding="async" />
    </picture>

    <aside class="cmp-course" data-reveal>
      <img src="/img/icon-atom.svg" alt="" aria-hidden="true" class="cmp-icon" width="40" height="40" />
      <h3 class="cmp-course__title">{course.title}</h3>
      <p class="cmp-course__body">{course.body}</p>
      <CtaButton label={course.cta.label} href={course.cta.href} variant="brand" size="lg" />
    </aside>

    <aside class="cmp-portion" data-reveal>
      <img src="/img/icon-molecule.svg" alt="" aria-hidden="true" class="cmp-icon" width="40" height="40" />
      <h3 class="cmp-portion__title">{portion.title}</h3>
      <p class="cmp-portion__body">{portion.body}</p>
    </aside>

    <hr class="cmp-line cmp-line--left" aria-hidden="true" data-cmp-line-left />
    <hr class="cmp-line cmp-line--right" aria-hidden="true" data-cmp-line-right />
  </div>
</section>

<style>
  .cmp-section {
    background: var(--color-surface);
    padding-block: var(--space-section-lg);
  }
  .cmp-grid {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 600px) minmax(0, 1fr);
    grid-template-rows: auto auto;
    column-gap: clamp(24px, 4vw, 80px);
    row-gap: clamp(40px, 8vh, 80px);
    align-items: start;
  }
  .cmp-head {
    grid-column: 1;
    grid-row: 1;
    display: flex;
    flex-direction: column;
    gap: 32px;
    max-width: 600px;
  }
  .cmp-title {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 48px;
    line-height: 1.1;
    letter-spacing: -0.01em;
    color: var(--color-ink);
  }
  .cmp-desc {
    display: flex;
    flex-direction: column;
    gap: 8px;
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 18px;
    line-height: 1.2;
    color: var(--color-muted);
    max-width: 600px;
  }
  .cmp-banka {
    grid-column: 2;
    grid-row: 1 / span 2;
    align-self: center;
    justify-self: center;
    display: block;
    width: 100%;
    max-width: 440px;
  }
  .cmp-banka img {
    width: 100%;
    height: auto;
    display: block;
    transform: rotate(-2deg);
    filter: drop-shadow(0 30px 60px rgba(16, 42, 68, 0.18));
    animation: cmp-banka-float 6s ease-in-out infinite;
  }
  @keyframes cmp-banka-float {
    0%, 100% { transform: rotate(-2deg) translateY(0); }
    50% { transform: rotate(1deg) translateY(-18px); }
  }
  @media (prefers-reduced-motion: reduce) {
    .cmp-banka img { animation: none; }
  }
  .cmp-course {
    grid-column: 3;
    grid-row: 1 / span 2;
    display: flex;
    flex-direction: column;
    gap: 16px;
    align-items: flex-start;
    align-self: center;
    max-width: 600px;
  }
  .cmp-icon {
    width: 40px;
    height: 40px;
    display: block;
    margin-bottom: 32px;
  }
  .cmp-divider {
    width: 908px;
    max-width: 100%;
    height: 2px;
    border: 0;
    background: var(--color-line-2);
    margin: 0;
  }
  .cmp-portion {
    grid-column: 1;
    grid-row: 2;
    display: flex;
    flex-direction: column;
    gap: 16px;
    align-items: flex-start;
    align-self: end;
    max-width: 597px;
  }
  .cmp-line {
    position: absolute;
    top: -16px;
    height: 2px;
    background: var(--color-line-2);
    border: 0;
    margin: 0;
    pointer-events: none;
    z-index: 0;
  }
  .cmp-banka {
    position: relative;
    z-index: 1;
  }
  .cmp-course,
  .cmp-portion {
    position: relative;
    z-index: 2;
  }
  .cmp-course__title,
  .cmp-portion__title {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 32px;
    line-height: 1.1;
    color: var(--color-ink);
  }
  .cmp-course__body,
  .cmp-portion__body {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 18px;
    line-height: 1.2;
    color: var(--color-muted);
  }

  @media (min-width: 1024px) and (max-width: 1279px) {
    .cmp-grid {
      grid-template-columns: minmax(0, 1fr) minmax(280px, 440px) minmax(0, 1fr);
      column-gap: 24px;
    }
    .cmp-banka { max-width: 360px; }
    .cmp-head { gap: 24px; }
    .cmp-title { font-size: 40px; }
    .cmp-desc { font-size: 16px; }
    .cmp-course__title,
    .cmp-portion__title { font-size: 26px; }
    .cmp-course__body,
    .cmp-portion__body { font-size: 16px; }
  }

  @media (max-width: 1023px) {
    .cmp-section {
      padding-block: 32px;
      padding-inline: 16px;
      overflow: hidden;
    }
    .cmp-section .container-page { padding-inline: 0; }
    .cmp-grid {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      grid-template-rows: auto auto;
      column-gap: 16px;
      row-gap: 24px;
    }
    .cmp-head {
      grid-column: 1 / -1;
      grid-row: 1;
      gap: 24px;
      max-width: 100%;
    }
    .cmp-title {
      font-size: 32px;
      line-height: 1.1;
      letter-spacing: -0.01em;
    }
    .cmp-desc {
      font-size: 16px;
      line-height: 1.2;
      gap: 4px;
      max-width: 100%;
    }
    .cmp-portion {
      grid-column: 1;
      grid-row: 2;
      align-self: start;
      max-width: 199px;
      gap: 12px;
    }
    .cmp-course {
      grid-column: 1;
      grid-row: 2;
      align-self: end;
      max-width: 199px;
      gap: 12px;
      margin-top: 200px;
    }
    .cmp-banka {
      grid-column: 2;
      grid-row: 2;
      justify-self: end;
      align-self: stretch;
      max-width: none;
      width: 298px;
      height: 100%;
      overflow: visible;
      margin-right: -16px;
      position: relative;
    }
    .cmp-banka img {
      width: 298px;
      height: 100%;
      max-width: none;
      object-fit: contain;
      object-position: left center;
      transform: translateX(50%) !important;
      animation: none !important;
      filter: none;
    }
    .cmp-icon {
      width: 32px;
      height: 32px;
      margin-bottom: 0;
    }
    .cmp-divider, .cmp-line { display: none; }
    .cmp-course__title,
    .cmp-portion__title {
      font-size: 20px;
      line-height: 1.2;
    }
    .cmp-course__body,
    .cmp-portion__body {
      font-size: 16px;
      line-height: 1.2;
    }
  }
</style>

<script>
  const grid = document.querySelector<HTMLElement>(".cmp-grid");
  const portion = document.querySelector<HTMLElement>(".cmp-portion");
  const course = document.querySelector<HTMLElement>(".cmp-course");
  const portionIcon = document.querySelector<HTMLElement>(".cmp-portion .cmp-icon");
  const courseIcon = document.querySelector<HTMLElement>(".cmp-course .cmp-icon");
  const portionTitle = document.querySelector<HTMLElement>(".cmp-portion__title");
  const courseTitle = document.querySelector<HTMLElement>(".cmp-course__title");
  const lineL = document.querySelector<HTMLElement>("[data-cmp-line-left]");
  const lineR = document.querySelector<HTMLElement>("[data-cmp-line-right]");

  const place = (icon: HTMLElement, title: HTMLElement, line: HTMLElement, leftOffset: number, width: number, gTop: number) => {
    const ir = icon.getBoundingClientRect();
    const tr = title.getBoundingClientRect();
    const lineH = line.getBoundingClientRect().height || 2;
    const mid = (ir.bottom + tr.top) / 2;
    line.style.top = (mid - gTop - lineH / 2) + "px";
    line.style.left = leftOffset + "px";
    line.style.width = width + "px";
  };

  const update = () => {
    if (!grid) return;
    const g = grid.getBoundingClientRect();
    const cs = getComputedStyle(grid);
    const padL = parseFloat(cs.paddingLeft) || 0;
    const padR = parseFloat(cs.paddingRight) || 0;
    const contentWidth = g.width - padL - padR;
    const half = contentWidth / 2;
    if (portionIcon && portionTitle && lineL) place(portionIcon, portionTitle, lineL, padL, half, g.top);
    if (courseIcon && courseTitle && lineR) place(courseIcon, courseTitle, lineR, padL + half, half, g.top);
  };

  const schedule = () => requestAnimationFrame(update);

  update();
  window.addEventListener("resize", schedule);
  window.addEventListener("load", schedule);
  window.addEventListener("scroll", schedule, { passive: true });
  // re-place after reveal transitions finish (data-reveal translates Y by 28px)
  [portion, course].forEach((el) => {
    el?.addEventListener("transitionend", schedule);
  });
  // re-place when fonts load (text metrics change)
  if (document.fonts?.ready) document.fonts.ready.then(schedule);
  // safety net: re-place on any size change of grid or referenced elements
  if ("ResizeObserver" in window) {
    const ro = new ResizeObserver(schedule);
    [grid, portion, course, portionIcon, courseIcon, portionTitle, courseTitle].forEach((el) => {
      if (el) ro.observe(el);
    });
  }
</script>
