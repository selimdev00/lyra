---
interface Props {
  label: string;
  href: string;
  variant?: "white" | "brand";
  size?: "md" | "lg";
  ariaLabel?: string;
  class?: string;
}
const {
  label,
  href,
  variant = "white",
  size = "md",
  ariaLabel,
  class: extraClass = "",
} = Astro.props;

const padText = size === "lg" ? "px-6 py-4 text-2xl leading-6" : "px-6 py-3 text-lg";
const padIcon = size === "lg" ? "p-4" : "p-3";
const iconSize = 24;

const palette =
  variant === "brand"
    ? "bg-[#1f5d80] text-white hover:bg-[color:var(--color-brand-dark)]"
    : "bg-white text-[color:var(--color-brand-dark)] hover:bg-white/95";
---

<a
  href={href}
  aria-label={ariaLabel ?? label}
  class={`group inline-flex items-center gap-0 ${extraClass}`}
>
  <span
    class={`${padText} rounded-pill ${palette} font-medium leading-6 whitespace-nowrap transition-colors shadow-sm`}
  >
    {label}
  </span>
  <span
    aria-hidden="true"
    class={`grid place-items-center ${padIcon} rounded-pill ${palette} transition-transform group-hover:translate-x-0.5 shadow-sm`}
  >
    <svg
      width={iconSize}
      height={iconSize}
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2.4"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="M7 17 17 7" />
      <path d="M9 7h8v8" />
    </svg>
  </span>
</a>
