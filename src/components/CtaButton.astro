---
interface Props {
  label: string;
  href: string;
  variant?: "white" | "brand";
  size?: "md" | "lg";
  ariaLabel?: string;
  class?: string;
}
const {
  label,
  href,
  variant = "white",
  size = "md",
  ariaLabel,
  class: extraClass = "",
} = Astro.props;

const classes = ["cta-btn", `cta-btn--${variant}`, `cta-btn--${size}`, extraClass]
  .filter(Boolean)
  .join(" ");
---

<a href={href} aria-label={ariaLabel ?? label} class={classes}>
  <span class="cta-btn__label">{label}</span>
  <span class="cta-btn__icon" aria-hidden="true">
    <svg
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2.4"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="M7 17 17 7" />
      <path d="M9 7h8v8" />
    </svg>
  </span>
</a>
