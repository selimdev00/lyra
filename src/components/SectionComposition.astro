---
import CtaButton from "./CtaButton.astro";

interface Row {
  name: string;
  role: string;
}
interface Props {
  titleLead: string;
  titleAccent: string;
  image: string;
  cta: { label: string; href: string };
  rows: Row[];
}
const { titleLead, titleAccent, image, cta, rows } = Astro.props;
---

<section id="composition" class="comp-section">
  <div class="container-page">
    <div class="comp-card" data-reveal>
      <div class="comp-card__media">
        <picture>
          <source srcset={image} type="image/webp" />
          <img
            src="/img/scoop.jpg"
            alt="Мерная ложка с порошком Complex SW Суставы"
            width="713"
            height="810"
            loading="lazy"
            decoding="async"
          />
        </picture>
      </div>

      <div class="comp-card__body">
        <h2 class="comp-card__title">
          <span>{titleLead}</span>
          <span class="comp-card__title--accent">{titleAccent}</span>
        </h2>

        <ul class="comp-card__grid">
          {rows.map((r) => (
            <li class="comp-item">
              <p class="comp-item__name">{r.name}</p>
              <p class="comp-item__role">{r.role}</p>
            </li>
          ))}
          <li class="comp-cta">
            <CtaButton label={cta.label} href={cta.href} variant="brand" size="lg" />
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .comp-section {
    padding-top: 0;
    padding-bottom: clamp(80px, 12vh, 160px);
    background: #f3f3f3;
    position: relative;
    margin-top: 0;
  }
  .comp-card {
    position: relative;
    z-index: 4;
    background: #fff;
    border-radius: 40px;
    padding: 40px 80px 40px 40px;
    display: grid;
    grid-template-columns: 713px minmax(0, 1fr);
    gap: 80px;
    align-items: start;
    box-shadow: 0 12px 40px -24px rgba(16, 42, 68, 0.18);
  }
  .comp-card__media {
    border-radius: 16px;
    overflow: hidden;
    background: #9ad5ef;
    width: 713px;
    height: 810px;
  }
  .comp-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .comp-card__body {
    display: flex;
    flex-direction: column;
    gap: 40px;
    padding-top: 62px;
  }
  .comp-card__title {
    font-family: "Onest", sans-serif;
    font-weight: 500;
    font-size: 48px;
    line-height: 1.1;
    letter-spacing: -0.01em;
    color: #1c1c1c;
  }
  .comp-card__title--accent {
    color: #3193cc;
  }
  .comp-card__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 451px));
    gap: 32px 24px;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .comp-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .comp-item__name {
    font-family: "Onest", sans-serif;
    font-weight: 500;
    font-size: 24px;
    line-height: 1.2;
    color: #1c1c1c;
  }
  .comp-item__role {
    font-family: "Onest", sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 1.2;
    color: #6b6b6b;
  }
  .comp-cta {
    margin-top: 8px;
  }

  @media (min-width: 1024px) and (max-width: 1279px) {
    .comp-card {
      grid-template-columns: minmax(0, 1fr);
      padding: 40px;
      gap: 40px;
    }
    .comp-card__media {
      width: 100%;
      height: auto;
      aspect-ratio: 713 / 480;
      max-height: 480px;
    }
    .comp-card__body { padding-top: 0; }
    .comp-card__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 1023px) {
    .comp-section {
      padding-block: 16px;
      padding-inline: 16px;
    }
    .comp-section .container-page { padding-inline: 0; }
    .comp-card {
      display: flex;
      flex-direction: column;
      padding: 16px;
      gap: 16px;
      border-radius: 16px;
    }
    .comp-card__media {
      order: 2;
      width: 100%;
      height: 240px;
      border-radius: 8px;
    }
    .comp-card__body {
      display: contents;
    }
    .comp-card__title {
      order: 1;
    }
    .comp-card__grid {
      order: 3;
    }
    .comp-card__title {
      font-size: 32px;
      line-height: 1.1;
      letter-spacing: -0.01em;
    }
    .comp-card__grid {
      display: flex;
      flex-direction: column;
      gap: 16px;
    }
    .comp-item__name { font-size: 18px; line-height: 1.2; }
    .comp-item__role { font-size: 14px; line-height: 1.2; }
  }
</style>
